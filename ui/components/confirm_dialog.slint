import { Palette } from "../palette.slint";
import { Button } from "std-widgets.slint";

export component ConfirmDialog inherits Dialog {
    in property <bool> open: false;
    in property <string> message: "Apakah Anda yakin?";
    in property <string> confirm-text: "Ya";
    in property <string> cancel-text: "Batal";
    callback confirmed();
    callback cancelled();
    visible: open;
    VerticalLayout {
        padding: 20px;
        spacing: 16px;
        HorizontalLayout {
            alignment: start;
            spacing: 12px;
            Rectangle {
                width: 40px;
                height: 40px;
                background: #fef3c7;
                border-radius: 8px;
                Text {
                    text: "⚠";
                    font-size: 22px;
                    color: #d97706;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                text: root.title;
                font-size: 18px;
                font-weight: 600;
                color: Palette.text_primary;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.message;
            font-size: 14px;
            color: Palette.text_secondary;
            wrap: word-wrap;
            horizontal-alignment: left;
        }

        Rectangle {
            vertical-stretch: 1;
        }
    }

    Button {
        text: root.cancel-text;
        dialog-button-role: reject;
        clicked => {
            root.cancelled();
        }
    }

    Button {
        text: root.confirm-text;
        dialog-button-role: accept;
        // In original design, confirm button had a danger style (red).
        // Standard Button does not support background color customization easily, 
        // but we can just use the default dialog button styling as requested.
        clicked => {
            root.confirmed();
        }
    }
}
