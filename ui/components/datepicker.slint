// Custom DatePickerPopup with smaller size
// Uses project Palette for styling

import { Button } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { Date, DatePickerBase } from "common/datepicker_base.slint";

export { Date }

component MenuBorder inherits Rectangle {
    border-radius: 6px;
    background: Palette.bg_surface_1;
    drop-shadow-blur: 12px;
    drop-shadow-offset-y: 4px;
    drop-shadow-color: #00000040;
    Rectangle {
        border-width: 1px;
        border-radius: parent.border-radius;
        border-color: Palette.border;
    }
}

export component DatePickerPopup inherits PopupWindow {
    in property <string> title: "Pilih Tanggal";
    in property <Date> date <=> base.date;
    callback canceled();
    callback accepted(date: Date);
    close-policy: PopupClosePolicy.no-auto-close;
    background-layer := MenuBorder {
        width: 100%;
        height: 100%;
    }

    VerticalLayout {
        padding: 8px;
        spacing: 6px;
        base := DatePickerBase {
            title: root.title;
            style: {
                border-brush: Palette.border,
                vertical-spacing: 4px,
                horizontal-spacing: 4px,
                calendar-style: {
                    spacing: 4px,
                    delegate-style: {
                        font-size: 10px,
                        font-weight: 500,
                        foreground: Palette.text_primary,
                        state-brush: Palette.text_secondary,
                        background-selected: Palette.accent,
                        foreground-selected: Palette.bg,
                        state-brush-selected: Palette.ancent-hover,
                        border-color-today: Palette.accent,
                        foreground-today: Palette.accent,
                        state-brush-today: Palette.text_secondary,
                    }
                },
                icon-button-style: {
                    foreground: Palette.icon_default,
                    state-brush: Palette.icon_hover,
                    icon-size: 12px,
                },
                current-day-style: {
                    font-size: 14px,
                    font-weight: 600,
                    foreground: Palette.text_primary,
                },
                title-style: {
                    font-size: 11px,
                    font-weight: 400,
                    foreground: Palette.text_secondary,
                },
                previous-icon: @image-url(""),
                next-icon: @image-url(""),
                drop-down-icon: @image-url(""),
                input-icon: @image-url(""),
                calendar-icon: @image-url(""),
                selection-button-style: {
                    foreground: Palette.text_primary,
                    state-brush: Palette.text_secondary,
                    icon-size: 8px,
                    font-size: 11px,
                    font-weight: 500
                }
            };
        }

        // Buttons
        HorizontalLayout {
            spacing: 6px;
            alignment: end;
            Button {
                text: "Batal";
                colorize-icon: true;
                clicked => {
                    root.close();
                    root.canceled();
                }
            }

            Button {
                text: "OK";
                enabled: base.ok-enabled();
                primary: true;
                clicked => {
                    root.close();
                    root.accepted(base.get-current-date());
                }
            }
        }
    }
}
