// Custom TableView Component
// Based on Slint's StandardTableView with modified styling

import { ListView } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { CustomCheckBox } from "checkbox.slint";

import { ContextMenuItem, CustomContextMenu } from "context_menu.slint";

// Komponen kolom header tabel
component TableViewColumn inherits Rectangle {
    in property <SortOrder> sort-order: SortOrder.unsorted;
    callback clicked <=> touch-area.clicked;
    background: Palette.bg_surface_2;
    states [
        pressed when touch-area.pressed: {
            background: Palette.bg_surface_hover;
        }
        hover when touch-area.has-hover: {
            background: Palette.bg_surface_hover;
        }
    ]
    touch-area := TouchArea {
        width: 100%;
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 4px;
        HorizontalLayout {
            @children
        }

        // Sort indicator icon
        if root.sort-order != SortOrder.unsorted: Rectangle {
            width: 16px;
            height: 16px;
            y: (parent.height - self.height) / 2;
            Text {
                width: 100%;
                height: 100%;
                text: root.sort-order == SortOrder.ascending ? "▲" : "▼";
                font-size: 12px;
                color: Palette.text_secondary;
            }
        }
    }

    // Bottom border
    Rectangle {
        y: parent.height - self.height;
        width: 100%;
        height: 1px;
        background: Palette.border;
    }
}

// Komponen cell tabel
component TableViewCell inherits Rectangle {
    clip: true;
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        @children
    }
}

// Komponen row tabel
component TableViewRow inherits Rectangle {
    in property <bool> selected;
    in property <bool> even;
    callback clicked <=> touch-area.clicked;
    callback pointer-event(event: PointerEvent, position: Point);
    min-width: layout.min-width;
    min-height: max(36px, layout.min-height);
    border-radius: 4px;
    background: root.even ? transparent : Palette.bg_surface_1;
    states [
        pressed when touch-area.pressed: {
            root.background: Palette.bg_surface_hover;
        }
        hover when touch-area.has-hover: {
            root.background: Palette.bg_surface_hover;
            selector.height: root.selected ? 16px : 0;
        }
        selected when root.selected: {
            root.background: Palette.selected_container;
            selector.height: 16px;
        }
    ]
    touch-area := TouchArea {
        pointer-event(pe) => {
            root.pointer-event(pe, {
                x: self.absolute-position.x + self.mouse-x,
                y: self.absolute-position.y + self.mouse-y,
            });
        }
    }

    layout := HorizontalLayout {
        @children
    }

    // Selection indicator (left bar)
    selector := Rectangle {
        x: 0px;
        y: (parent.height - self.height) / 2;
        width: 3px;
        height: 0px;
        background: Palette.accent;
        border-radius: 2px;
        animate height {
            duration: 150ms;
            easing: ease-out;
        }
    }
}

// Komponen utama CustomTableView
export component CustomTableView {
    in-out property <length> rows-font-size: 12px;
    in property <[[StandardListViewItem]]> rows;
    out property <int> current-sort-column: -1;
    in-out property <[TableColumn]> columns;
    in-out property <int> current-row: -1;
    in property <bool> multi-select: true;
    in property <bool> show-selection-column: true;
    in property <length> selection-checkbox-size: 14px;
    in property <length> selection-column-width: max(32px, root.selection-checkbox-size + 12px);
    in property <[ContextMenuItem]> context-menu-items: [];
    in property <bool> context-menu-enabled: root.rows.length > 0 && root.context-menu-items.length > 0;
    in-out property <bool> select-all: false;
    in-out property <int> selection-anchor: -1;
    in-out property <int> selection-start: -1;
    in-out property <int> selection-end: -1;
    in property <bool> enabled <=> scroll-view.enabled;
    out property <length> visible-width <=> scroll-view.visible-width;
    out property <length> visible-height <=> scroll-view.visible-height;
    in-out property <bool> has-focus <=> scroll-view.has-focus;
    in-out property <length> viewport-width <=> scroll-view.viewport-width;
    in-out property <length> viewport-height <=> scroll-view.viewport-height;
    in-out property <length> viewport-x <=> scroll-view.viewport-x;
    in-out property <length> viewport-y <=> scroll-view.viewport-y;
    callback sort-ascending(column: int);
    callback sort-descending(column: int);
    callback row-pointer-event(row: int, event: PointerEvent, position: Point);
    callback context-menu-activated(action: string);
    callback current-row-changed(current-row: int);
    public function set-current-row(index: int) {
        if (index < 0 || index >= rows.length) {
            return;
        }
        current-row = index;
        current-row-changed(current-row);
        if (current-item-y < 0) {
            scroll-view.viewport-y += 0 - current-item-y;
        }
        if (current-item-y + item-height > scroll-view.visible-height) {
            scroll-view.viewport-y -= current-item-y + item-height - scroll-view.visible-height;
        }
    }
    private property <length> min-header-height: 40px;
    private property <length> item-height: scroll-view.viewport-height / rows.length;
    private property <length> current-item-y: scroll-view.viewport-y + current-row * item-height;
    private property <bool> has-selection: selection-start >= 0 && selection-end >= 0;
    private property <int> selection-low: min(selection-start, selection-end);
    private property <int> selection-high: max(selection-start, selection-end);
    out property <int> selected-count: root.rows.length > 0 ? (root.has-selection ? (root.selection-high - root.selection-low + 1) : (root.current-row >= 0 && root.current-row < root.rows.length ? 1 : 0)) : 0;
    property <length> context-menu-pos-x;
    property <length> context-menu-pos-y;
    function sort(index: int) {
        if (root.current-sort-column != index) {
            root.columns[root.current-sort-column].sort-order = SortOrder.unsorted;
        }
        if (root.columns[index].sort-order == SortOrder.ascending) {
            root.columns[index].sort-order = SortOrder.descending;
            root.sort-descending(index);
        } else {
            root.columns[index].sort-order = SortOrder.ascending;
            root.sort-ascending(index);
        }
        root.current-sort-column = index;
    }
    function clear-selection() {
        root.selection-start = -1;
        root.selection-end = -1;
        root.selection-anchor = -1;
        root.select-all = false;
    }
    function apply-selection-range(start: int, end: int) {
        if (rows.length <= 0 || start < 0 || end < 0) {
            root.clear-selection();
            return;
        }
        root.selection-start = start;
        root.selection-end = end;
        root.select-all = min(start, end) == 0 && max(start, end) == rows.length - 1;
    }
    function select-row(index: int, shift: bool, ctrl: bool) {
        if (index < 0 || index >= rows.length) {
            return;
        }
        root.focus();
        root.set-current-row(index);
        if (root.multi-select) {
            if (shift && root.selection-anchor >= 0) {
                root.apply-selection-range(root.selection-anchor, index);
                return;
            }
            if (ctrl) {
                if (root.has-selection) {
                    root.selection-anchor = index;
                    root.apply-selection-range(min(root.selection-low, index), max(root.selection-high, index));
                } else {
                    root.selection-anchor = index;
                    root.apply-selection-range(index, index);
                }
                return;
            }
        }
        root.selection-anchor = index;
        root.apply-selection-range(index, index);
    }
    function toggle-select-all(checked: bool) {
        if (checked && rows.length > 0) {
            root.selection-anchor = 0;
            root.apply-selection-range(0, rows.length - 1);
        } else {
            root.clear-selection();
        }
    }
    min-width: 400px;
    min-height: 200px;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    forward-focus: focus-scope;
    accessible-role: table;

    // Main content layer
    VerticalLayout {
        width: 100%;
        height: 100%;
        // Header section
        header-rect := Rectangle {
            clip: true;
            vertical-stretch: 0;
            min-height: header-layout.min-height;
            background: Palette.bg_surface_2;
            border-radius: 4px;
            header-layout := HorizontalLayout {
                width: max(self.preferred-width, parent.width);
                x: scroll-view.viewport-x;
                padding-right: 6px;
                min-height: root.min-header-height;
                if root.show-selection-column: Rectangle {
                    preferred-width: root.selection-column-width;
                    min-width: root.selection-column-width;
                    max-width: root.selection-column-width;
                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            alignment: center;
                            CustomCheckBox {
                                size: root.selection-checkbox-size;
                                enabled: root.rows.length > 0;
                                checked <=> root.select-all;
                                toggled => {
                                    root.toggle-select-all(self.checked);
                                }
                            }
                        }
                    }
                }
                for column[index] in root.columns: TableViewColumn {
                    sort-order: column.sort-order;
                    horizontal-stretch: column.horizontal-stretch;
                    min-width: max(column.min-width, column.width);
                    preferred-width: self.min-width;
                    max-width: (index < columns.length && column.width >= 1px) ? max(column.min-width, column.width) : 100000px;
                    clicked => {
                        root.sort(index);
                    }
                    Text {
                        vertical-alignment: center;
                        text: column.title;
                        font-weight: 600;
                        font-size: 12px;
                        color: Palette.text_secondary;
                        overflow: elide;
                    }
                }
            }
        }

        // Data rows section - ListView wrapped in Rectangle to get dimensions
        list-container := Rectangle {
            vertical-stretch: 1;
            scroll-view := ListView {
                for row[idx] in root.rows: TableViewRow {
                    property <bool> row-selected: root.select-all || (root.has-selection && idx >= root.selection-low && idx <= root.selection-high) || (!root.has-selection && idx == root.current-row);
                    selected: row-selected;
                    even: mod(idx, 2) == 0;
                    pointer-event(pe, pos) => {
                        root.row-pointer-event(idx, pe, {
                            x: pos.x - root.absolute-position.x,
                            y: pos.y - root.absolute-position.y,
                        });
                        if (pe.kind == PointerEventKind.down && pe.button == PointerEventButton.left) {
                            root.select-row(idx, pe.modifiers.shift, pe.modifiers.control);
                        }
                        if (pe.kind == PointerEventKind.down && pe.button == PointerEventButton.right) {
                            if (!root.has-selection || idx < root.selection-low || idx > root.selection-high) {
                                root.select-row(idx, false, false);
                            }
                            if (root.context-menu-enabled) {
                                root.context-menu-pos-x = pos.x - root.absolute-position.x;
                                root.context-menu-pos-y = pos.y - root.absolute-position.y;
                                context-menu.show();
                            }
                        }
                    }
                    clicked => {
                        root.focus();
                    }
                    if root.show-selection-column: Rectangle {
                        preferred-width: root.selection-column-width;
                        min-width: root.selection-column-width;
                        max-width: root.selection-column-width;
                        background: transparent;
                    }
                    for cell[index] in row: TableViewCell {
                        horizontal-stretch: root.columns[index].horizontal-stretch;
                        min-width: max(columns[index].min-width, columns[index].width);
                        preferred-width: self.min-width;
                        max-width: (index < columns.length && columns[index].width >= 1px) ? max(columns[index].min-width, columns[index].width) : 100000px;
                        Rectangle {
                            Text {
                                width: 100%;
                                height: 100%;
                                overflow: elide;
                                vertical-alignment: center;
                                text: cell.text;
                                font-size: root.rows-font-size;
                                color: mod(idx, 2) == 0 ? Palette.text_primary : Palette.text_secondary;
                            }
                        }
                    }
                }
            }
        }
    }

    context-menu := CustomContextMenu {
        x: root.context-menu-pos-x;
        y: root.context-menu-pos-y;
        items: root.context-menu-items;
        activated(action) => {
            root.context-menu-activated(action);
        }
    }

    // Keyboard navigation
    focus-scope := FocusScope {
        x: 0;
        width: 0;
        key-pressed(event) => {
            if (event.text == Key.UpArrow) {
                root.select-row(root.current-row - 1, event.modifiers.shift, event.modifiers.control);
                return accept;
            } else if (event.text == Key.DownArrow) {
                root.select-row(root.current-row + 1, event.modifiers.shift, event.modifiers.control);
                return accept;
            }
            reject
        }
    }
}
