import { Palette } from "../palette.slint";

export struct ContextMenuItem {
    title: string,
    icon: image,
    action: string,
    disabled: bool,
}

export component CustomContextMenu inherits PopupWindow {
    in property <[ContextMenuItem]> items;
    in property <length> menu-width: 180px;
    callback activated(string);
    width: root.menu-width;
    Rectangle {
        width: 100%;
        height: 100%;
        background: Palette.bg_surface_1;
        border-color: Palette.border;
        border-width: 1px;
        border-radius: 6px;
        drop-shadow-color: #0000002A;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 6px;
        VerticalLayout {
            padding: 4px;
            for item[index] in root.items: item-bg := Rectangle {
                height: 32px;
                border-radius: 4px;
                background: transparent;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;
                    if item.icon.width > 0: VerticalLayout {
                        alignment: center;
                        Image {
                            source: item.icon;
                            width: 16px;
                            height: 16px;
                            colorize: item.disabled ? Palette.muted : Palette.text_secondary;
                        }
                    }
                    text := Text {
                        text: item.title;
                        font-size: 13px;
                        font-weight: 500;
                        color: Palette.text_primary;
                        vertical-alignment: center;
                    }
                }

                ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    mouse-cursor: pointer;
                    clicked => {
                        if (!item.disabled) {
                            root.activated(item.action);
                            root.close();
                        }
                    }
                }

                states [
                    disabled when item.disabled: {
                        ta.mouse-cursor: default;
                        text.color: Palette.muted;
                        item-bg.background: transparent;
                    }
                    pressed when ta.pressed: {
                        item-bg.background: Palette.bg_surface_2;
                    }
                    hover when ta.has-hover: {
                        item-bg.background: Palette.bg_surface_hover;
                    }
                ]
            }
        }
    }
}
