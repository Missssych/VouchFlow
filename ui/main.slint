import { Palette } from "palette.slint";
import { Header, Footer, ConfirmDialog } from "components/widgets.slint";
import { Sidebar } from "sidebar.slint";
import {
    Dashboard,
    Produk,
    MasterData,
    Utility,
    Settings,
    LogsTerminal,
} from "pages/page.slint";
import {
    AppState,
    ProdukState,
    StokState,
    UtilityState,
    DashboardState,
    SettingsState,
    LogsState,
} from "state.slint";
export { AppState, ProdukState, StokState, UtilityState, DashboardState, SettingsState, LogsState }

export component AppWindow inherits Window {
    min-width: 1150px;
    min-height: 650px;
    title: "MainWindow";
    icon: @image-url("../assets/rv_icon_256.png");
    no-frame: true;
    background: transparent;
    
    // Property for close confirmation dialog
    private property <bool> show-close-dialog: false;
    
    // Window control callbacks
    callback close_window();
    callback minimize_window();
    callback maximize_window();
    callback move_window();
    
    // Menu change callback
    callback menu-changed(int);
    
    // Background with rounded corners
    Rectangle {
        border-radius: AppState.is-maximized ? 0px : 12px;
        clip: true;
        background: Palette.bg;
    }
    
    // Main layout: Header → Body → Footer
    VerticalLayout {
        // ============================================
        // HEADER (34px)
        // ============================================
        Header {
            is-connected: AppState.server-connected;
            status-text: AppState.server-status;
            close-window => {
                // Check if server is connected before closing
                if (AppState.server-connected) {
                    root.show-close-dialog = true;
                } else {
                    root.close_window();
                }
            }
            minimize-window => {
                root.minimize_window();
            }
            maximize-window => {
                root.maximize_window();
            }
            move-window => {
                root.move_window();
            }
        }
        
        // ============================================
        // BODY (flex 1) - Sidebar + Content
        // ============================================
        HorizontalLayout {
            vertical-stretch: 1;
            padding-left: 6px;
            padding-right: 6px;
            spacing: 6px;
            
            // Sidebar (collapsible)
            sidebar := Sidebar {
                active-menu: AppState.active-tab;
                menu-changed(index) => {
                    AppState.active-tab = index;
                    AppState.tab-changed(index);
                    root.menu-changed(index);
                }
            }
            
            // Content Area
            Rectangle {
                horizontal-stretch: 1;
                if AppState.active-tab == 0: Dashboard { }
                if AppState.active-tab == 1: Produk { }
                if AppState.active-tab == 2: MasterData { }
                if AppState.active-tab == 3: Utility { }
                if AppState.active-tab == 4: LogsTerminal { }
                if AppState.active-tab == 5: Settings { }
                
                // Drag area for window movement
                TouchArea {
                    z: -1;
                    moved => {
                        root.move_window();
                    }
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            root.move_window();
                        }
                    }
                }
            }
        }
        
        // ============================================
        // FOOTER (28px)
        // ============================================
        Footer {
            version: AppState.app-version;
            current-time: AppState.current-time;
        }
    }
    
    // Close confirmation dialog overlay
    ConfirmDialog {
        open: root.show-close-dialog;
        title: "Konfirmasi Keluar";
        message: "Server sedang aktif. Apakah Anda yakin ingin menutup aplikasi? Server akan dihentikan.";
        confirm-text: "Keluar";
        cancel-text: "Batal";
        confirmed => {
            root.show-close-dialog = false;
            AppState.server-connected = false;
            root.close_window();
        }
        cancelled => {
            root.show-close-dialog = false;
        }
    }
}
