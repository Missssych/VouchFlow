import { Palette } from "../palette.slint";
import { ServerCogIcon, UserRoundCogIcon, Icons } from "@lucide";
import {
    CustomTextInput,
    CustomButton,
    CustomTabs,
} from "../components/widgets.slint";
import { AppState, SettingsState } from "../state.slint";
export component Settings inherits VerticalLayout {
    width: 100%;
    height: 100%;
    alignment: space-between;
    
    // Load config on init
    init => {
        SettingsState.load-config();
    }
    Rectangle {
        width: 100%;
        height: 45%;
        background: Palette.bg_surface_1;
        border-radius: 8px;
        GridLayout {
            padding: 12px;
            spacing: 8px;
            //Title
            HorizontalLayout {
                col: 0;
                row: 0;
                colspan: 4;
                spacing: 12px;
                ServerCogIcon {
                    width: 24px;
                    height: 24px;
                    colorize: Palette.text_secondary;
                }

                Text {
                    text: "Server Configuration";
                    font-size: 20px;
                    font-weight: 600;
                    color: Palette.text_secondary;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                col: 1;
                row: 1;
                width: 30%;
                alignment: start;
                spacing: 8px;
                Text {
                    text: "Alamat Server";
                    font-size: 14px;
                    font-weight: 600;
                    color: Palette.text;
                    vertical-alignment: center;
                }

                server-addr := CustomTextInput {
                    height: 40px;
                    placeholder: "127.0.0.1";
                    icon: Icons.ServerIcon;
                    text <=> SettingsState.server-address;
                    enabled: !SettingsState.server-running;
                }
            }

            VerticalLayout {
                col: 2;
                row: 1;
                width: 30%;
                alignment: start;
                spacing: 8px;
                Text {
                    text: "Alamat Webhook";
                    font-size: 14px;
                    font-weight: 600;
                    color: Palette.text;
                    vertical-alignment: center;
                }

                webhook-addr := CustomTextInput {
                    height: 40px;
                    placeholder: "127.0.0.1";
                    icon: Icons.WebhookIcon;
                    text <=> SettingsState.webhook-address;
                    enabled: !SettingsState.server-running;
                }
            }

            VerticalLayout {
                col: 1;
                row: 2;
                width: 30%;
                alignment: start;
                spacing: 8px;
                Text {
                    text: "Port Server";
                    font-size: 14px;
                    font-weight: 600;
                    color: Palette.text;
                    vertical-alignment: center;
                }

                server-port := CustomTextInput {
                    height: 40px;
                    input-type: number;
                    placeholder: "8080";
                    icon: Icons.ServerIcon;
                    text <=> SettingsState.server-port;
                    enabled: !SettingsState.server-running;
                }
            }

            VerticalLayout {
                col: 2;
                row: 2;
                width: 30%;
                alignment: start;
                spacing: 8px;
                Text {
                    text: "Port Webhook";
                    font-size: 14px;
                    font-weight: 600;
                    color: Palette.text;
                    vertical-alignment: center;
                }

                webhook-port := CustomTextInput {
                    height: 40px;
                    input-type: number;
                    placeholder: "8081";
                    icon: Icons.WebhookIcon;
                    text <=> SettingsState.webhook-port;
                    enabled: !SettingsState.server-running;
                }
            }

            HorizontalLayout {
                col: 1;
                row: 3;
                colspan: 2;
                alignment: end;
                spacing: 12px;
                
                // Status indicator
                Text {
                    text: SettingsState.server-running ? "● Server Running" : "○ Server Stopped";
                    font-size: 12px;
                    color: SettingsState.server-running ? #4ade80 : Palette.text_secondary;
                    vertical-alignment: center;
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                CustomButton {
                    width: 100px;
                    preferred-height: 30px;
                    max-height: 40px;
                    text: "Save";
                    icon: Icons.SaveIcon;
                    enabled: !SettingsState.server-running && !SettingsState.is-saving;
                    clicked => {
                        SettingsState.save-config(
                            SettingsState.server-address,
                            SettingsState.server-port,
                            SettingsState.webhook-address,
                            SettingsState.webhook-port);
                    }
                }

                CustomButton {
                    width: 100px;
                    preferred-height: 30px;
                    max-height: 40px;
                    text: SettingsState.server-running ? "Stop" : "Start";
                    icon: SettingsState.server-running ? Icons.SquareIcon : Icons.PlayIcon;
                    clicked => {
                        if (SettingsState.server-running) {
                            SettingsState.stop-server();
                        } else {
                            SettingsState.start-server();
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        private property <int> active-tab: 0;
        width: 100%;
        height: 54%;
        background: Palette.bg_surface_1;
        border-radius: 8px;
        GridLayout {
            padding: 12px;
            spacing: 8px;
            //Title
            HorizontalLayout {
                col: 0;
                row: 0;
                colspan: 3;
                spacing: 12px;
                UserRoundCogIcon {
                    width: 24px;
                    height: 24px;
                    colorize: Palette.text_secondary;
                }

                Text {
                    text: "Account Configuration";
                    font-size: 20px;
                    font-weight: 600;
                    color: Palette.text_secondary;
                    vertical-alignment: center;
                }
            }

            CustomTabs {
                col: 1;
                row: 1;
                tabs: [
                    { title: "Username", has-icon: true, icon: Icons.UserIcon },
                    { title: "Nomor HP", has-icon: true, icon: Icons.PhoneIcon },
                ];
                active-tab <=> active-tab;
                tab-changed(index) => {
                    active-tab = index;
                }
            }

            VerticalLayout {
                col: 1;
                row: 2;
                width: 50%;
                spacing: 8px;
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 8px;
                Text {
                    text: active-tab == 0 ? "Username" : "Nomor HP";
                    font-size: 14px;
                    font-weight: 600;
                    color: Palette.text;
                    vertical-alignment: center;
                }

                CustomTextInput {
                    height: 40px;
                    placeholder: active-tab == 0 ? "Username" : "08123xxxxxx";
                    icon: active-tab == 0 ? Icons.UserIcon : Icons.PhoneIcon;
                    enabled: false;
                }

                Text {
                    text: active-tab == 0 ? "Password" : "Otp";
                    font-size: 14px;
                    font-weight: 600;
                    color: Palette.text;
                    vertical-alignment: center;
                }

                CustomTextInput {
                    height: 40px;
                    placeholder: active-tab == 0 ? "Password" : "******";
                    icon: Icons.LockIcon;
                    input-type: active-tab == 0 ? password : text;
                    enabled: false;
                }

                HorizontalLayout {
                    spacing: 12px;
                    CustomButton {
                        width: 100px;
                        preferred-height: 30px;
                        max-height: 40px;
                        text: "Clear";
                        icon: Icons.EraserIcon;
                        enabled: false;
                    }

                    CustomButton {
                        width: 100px;
                        preferred-height: 30px;
                        max-height: 40px;
                        text: "Save";
                        icon: Icons.SaveIcon;
                        enabled: false;
                    }
                    //space
                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    CustomButton {
                        width: 100px;
                        preferred-height: 30px;
                        max-height: 40px;
                        text: "Login";
                        icon: Icons.LogInIcon;
                        enabled: false;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }
            }
        }
    }
}
