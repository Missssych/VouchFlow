import { Palette } from "../palette.slint";
import {
    CustomButton,
    CustomTableView,
    CustomComboBox,
    Switch,
} from "../components/widgets.slint";
import { TerminalIcon, Icons } from "@lucide";
import { LogsState } from "../state.slint";

export component LogsTerminal inherits Rectangle {
    private property <int> log-count: LogsState.logs.length;
    private property <bool> auto-scroll-enabled: LogsState.auto-scroll;
    private property <bool> paused-state: LogsState.paused;

    // Initialize on visibility
    init => {
        LogsState.load-logs();
    }

    changed log-count => {
        if (LogsState.auto-scroll && !LogsState.paused && log-count > 0) {
            log-table.set-current-row(log-count - 1);
        }
    }

    changed auto-scroll-enabled => {
        if (auto-scroll-enabled && !LogsState.paused && log-count > 0) {
            log-table.set-current-row(log-count - 1);
        }
    }

    changed paused-state => {
        if (!paused-state && LogsState.auto-scroll && log-count > 0) {
            log-table.set-current-row(log-count - 1);
        }
    }

    VerticalLayout {
        // Toolbar
        HorizontalLayout {
            height: 36px;
            spacing: 8px;
            padding-left: 6px;
            padding-right: 6px;
            // Title
            HorizontalLayout {
                spacing: 8px;
                width: 120px;
                TerminalIcon {
                    width: 20px;
                    height: 20px;
                    colorize: Palette.text_secondary;
                    y: parent.height / 2 - self.height / 2;
                }

                Text {
                    text: "Log Terminal";
                    font-size: 14px;
                    font-weight: 600;
                    color: Palette.text;
                    vertical-alignment: center;
                }
            }

            // Level filter
            Text {
                width: 40px;
                text: "Level:";
                font-size: 12px;
                vertical-alignment: center;
            }

            CustomComboBox {
                min-width: 80px;
                max-width: 100px;
                height: 28px;
                model: LogsState.level-options;
                current-index <=> LogsState.level-filter-index;
                y: parent.height / 2 - self.height / 2;
                selected(_value) => {
                    LogsState.load-logs();
                }
            }

            // Spacer
            Rectangle {
                horizontal-stretch: 1;
            }

            // Auto Scroll switch
            Switch {
                width: 120px;
                height: 28px;
                text: "Auto Scroll";
                checked <=> LogsState.auto-scroll;
                toggled => {
                    if (self.checked && !LogsState.paused && LogsState.logs.length > 0) {
                        log-table.set-current-row(LogsState.logs.length - 1);
                    }
                }
            }

            // Pause/Resume button
            CustomButton {
                width: 100px;
                height: 28px;
                text: LogsState.paused ? "Resume" : "Pause";
                icon: LogsState.paused ? Icons.PlayIcon : Icons.PauseIcon;
                border-radius: 4px;
                clicked => {
                    LogsState.toggle-pause();
                }
            }

            // Clear button
            CustomButton {
                width: 80px;
                height: 28px;
                text: "Clear";
                icon: Icons.Trash2Icon;
                border-radius: 4px;
                clicked => {
                    LogsState.clear-logs();
                }
            }
        }

        // Log table
        Rectangle {
            vertical-stretch: 1;
            log-table := CustomTableView {
                width: 100%;
                height: 100%;
                columns: [
                    { title: "Waktu", width: 180px },
                    { title: "Level", width: 60px },
                    { title: "Message" },
                    { title: "Trace ID", width: 100px },
                ];
                rows: LogsState.logs;
            }
        }

        // Status bar
        HorizontalLayout {
            height: 20px;
            spacing: 12px;
            Text {
                text: LogsState.paused ? "Paused" : "Live";
                font-size: 10px;
                color: LogsState.paused ? Palette.text_secondary : #4ade80;
                vertical-alignment: center;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            Text {
                text: "Max: 1000 entries (ring buffer)";
                font-size: 10px;
                color: Palette.text_secondary;
                vertical-alignment: center;
            }
        }
    }
}
